---
import { Code } from 'astro:components';

interface Tab {
  label: string;
  lang: string;
  code: string;
}
interface Props {
  tabs: Tab[];
}
const { tabs } = Astro.props;
const id = 'tabs-' + Math.random().toString(36).slice(2, 9);
---

<div class="codetabs" data-codetabs>
  <div class="ct-bar" role="tablist">
    {tabs.map((t, i) => (
      <button
        type="button"
        role="tab"
        class="ct-tab"
        data-tab={i}
        aria-selected={i === 0 ? 'true' : 'false'}
      >{t.label}</button>
    ))}
  </div>
  {tabs.map((t, i) => (
    <div class="ct-panel" data-panel={i} hidden={i !== 0}>
      <Code code={t.code} lang={t.lang} theme="github-light" />
    </div>
  ))}
</div>

<script>
  function initCodeTabs() {
    document.querySelectorAll('[data-codetabs]').forEach((root) => {
      if (root.dataset.ready) return;
      root.dataset.ready = '1';
      const tabs = root.querySelectorAll('[data-tab]');
      const panels = root.querySelectorAll('[data-panel]');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const i = tab.dataset.tab;
          tabs.forEach((t) => t.setAttribute('aria-selected', t === tab ? 'true' : 'false'));
          panels.forEach((p) => (p.hidden = p.dataset.panel !== i));
        });
      });
    });
  }
  initCodeTabs();
  document.addEventListener('astro:page-load', initCodeTabs);
</script>

<style>
  .codetabs {
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    margin: 1.25rem 0;
  }
  .ct-bar {
    display: flex;
    gap: 2px;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 0 6px;
  }
  .ct-tab {
    font: 500 12px var(--mono);
    padding: 10px 12px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--muted);
    cursor: pointer;
  }
  .ct-tab[aria-selected='true'] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .ct-panel :global(pre) {
    margin: 0;
    padding: 16px;
    font-size: 13px;
    line-height: 1.6;
    background: #fcfcfb !important;
  }
</style>
